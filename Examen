package ejercicio1;

/**
 * Representa un examen clínico realizado a un paciente.
 * Almacena el tipo de prueba (resonancia, biopsia, tomografía) y su resultado.
 */
public class Examen {
    private String idExamen;
    private String fecha;
    private String tipoExamen;
    private String resultado;

    /**
     * Crea un nuevo examen con todos sus datos.
     * @param idExamen   Identificador único del examen
     * @param fecha      Fecha en que se realizó el examen
     * @param tipoExamen Tipo de prueba (ej: biopsia, resonancia, tomografía)
     * @param resultado  Descripción del resultado obtenido
     */
    public Examen(String idExamen, String fecha, String tipoExamen, String resultado) {
        this.idExamen   = idExamen;
        this.fecha      = fecha;
        this.tipoExamen = tipoExamen;
        this.resultado  = resultado;
    }

    public String getIdExamen()   { return idExamen; }
    public String getFecha()      { return fecha; }
    public String getTipoExamen() { return tipoExamen; }
    public String getResultado()  { return resultado; }

    @Override
    public String toString() {
        return "[" + idExamen + "] " + tipoExamen + " (" + fecha + "): " + resultado;
    }
}
