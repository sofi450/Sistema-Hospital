package ejercicio1;

/**
 * Representa un tratamiento médico asignado a un paciente.
 * Puede ser Quimioterapia, Radioterapia, Cirugía o Inmunoterapia.
 */
public class Tratamiento {
    private String idTratamiento;
    private String nombre;
    private int    duracionDias;
    private String efectosSecundarios;

    /**
     * Crea un nuevo tratamiento con todos sus datos.
     * @param idTratamiento      Identificador único del tratamiento
     * @param nombre             Nombre del tratamiento (ej: Quimioterapia)
     * @param duracionDias       Duración estimada en días
     * @param efectosSecundarios Descripción de los efectos secundarios conocidos
     */
    public Tratamiento(String idTratamiento, String nombre,
                       int duracionDias, String efectosSecundarios) {
        this.idTratamiento      = idTratamiento;
        this.nombre             = nombre;
        this.duracionDias       = duracionDias;
        this.efectosSecundarios = efectosSecundarios;
    }

    /**
     * Calcula el porcentaje estimado de eficacia del tratamiento
     * según el tipo de cáncer del paciente.
     *
     * Lógica:
     *  - Leucemia  → responde mejor a Quimioterapia e Inmunoterapia (base 70%)
     *  - Linfoma   → responde bien a Radioterapia (base 65%)
     *  - Sarcoma   → responde mejor a Cirugía (base 60%)
     *
     * @param tipoCancer Tipo de cáncer del paciente (Sarcoma, Leucemia, Linfoma)
     * @return Porcentaje estimado de mejora (0.0 - 100.0)
     */
    public double calcularEficacia(String tipoCancer) {
        double base;

        switch (tipoCancer.toLowerCase()) {
            case "leucemia": base = 70.0; break;
            case "linfoma":  base = 65.0; break;
            case "sarcoma":  base = 60.0; break;
            default:         base = 50.0;
        }

        // No superar el 100%
        return Math.min(base, 100.0);
    }

    public String getIdTratamiento()      { return idTratamiento; }
    public String getNombre()             { return nombre; }
    public int    getDuracionDias()       { return duracionDias; }
    public String getEfectosSecundarios() { return efectosSecundarios; }

    @Override
    public String toString() {
        return "[" + idTratamiento + "] " + nombre + " - " + duracionDias + " días";
    }
}
